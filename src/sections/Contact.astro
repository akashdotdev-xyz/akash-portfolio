---
import { profile } from "../content/profile";

const {
  email,
  linkedin,
  github,
  resume,
} = profile.links;

const resumeUrl = resume
  ? `${import.meta.env.BASE_URL}${resume}`
  : undefined;
---

<section
  id="contact"
  class="contact-section"
>
  <div class="container">

    <div class="contact-card">

      <div class="contact-content">

        <span class="eyebrow">
          GET IN TOUCH
        </span>

        <h2>
          Let's build something
          <span>meaningful.</span>
        </h2>

        <p>
          I'm always interested in discussing backend
          engineering, distributed systems, product ideas,
          and interesting technical problems.
        </p>

      </div>

      <div class="contact-actions">

        {
          email && (
            <a
              href={`mailto:${email}`}
              class="primary-action"
            >
              Send me an email
              <span aria-hidden="true">→</span>
            </a>
          )
        }

        <div class="social-links">

          {
            linkedin && (
              <a
                href={linkedin}
                target="_blank"
                rel="noopener noreferrer"
              >
                LinkedIn
                <span aria-hidden="true">↗</span>
              </a>
            )
          }

          {
            github && (
              <a
                href={github}
                target="_blank"
                rel="noopener noreferrer"
              >
                GitHub
                <span aria-hidden="true">↗</span>
              </a>
            )
          }

        </div>

      </div>

    </div>

  </div>
</section>

<style>
  .contact-section {
    padding: 30px 0 96px;
  }

  .contact-card {
    display: grid;

    grid-template-columns:
      minmax(0, 1.3fr)
      minmax(240px, 0.7fr);

    align-items: center;

    gap: 72px;

    padding: 56px;

    border: 1px solid var(--border);
    border-radius: 18px;

    background: var(--surface);
  }

  .eyebrow {
    color: var(--accent);

    font-size: 0.7rem;
    font-weight: 700;

    letter-spacing: 0.12em;
  }

  h2 {
    max-width: 560px;

    margin: 12px 0 0;

    font-size:
      clamp(2rem, 4vw, 3rem);

    line-height: 1.08;

    letter-spacing: -0.05em;
  }

  h2 span {
    color: var(--accent);
  }

  .contact-content p {
    max-width: 580px;

    margin: 20px 0 0;

    color: var(--text-secondary);

    font-size: 0.95rem;
    line-height: 1.7;
  }

  .contact-actions {
    display: flex;
    flex-direction: column;

    gap: 22px;
  }

  .primary-action {
    display: flex;
    align-items: center;
    justify-content: space-between;

    padding: 15px 18px;

    border-radius: 8px;

    background: var(--accent);
    color: white;

    font-size: 0.88rem;
    font-weight: 650;

    transition:
      background 150ms ease,
      transform 150ms ease;
  }

  .primary-action:hover {
    background: var(--accent-dark);

    transform: translateY(-1px);
  }

  .primary-action span {
    transition: transform 150ms ease;
  }

  .primary-action:hover span {
    transform: translateX(3px);
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;

    gap: 18px;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;

    gap: 5px;

    color: var(--text-secondary);

    font-size: 0.82rem;
    font-weight: 550;

    transition: color 150ms ease;
  }

  .social-links a:hover {
    color: var(--text-primary);
  }

  .social-links span {
    color: var(--accent);

    font-size: 0.75rem;
  }

  @media (max-width: 800px) {
    .contact-card {
        grid-template-columns: minmax(0, 1fr);

        gap: 36px;

        padding: 40px;
    }

    .contact-content,
    .contact-actions {
        min-width: 0;
    }
    }

  @media (max-width: 520px) {
    .contact-section {
        padding: 24px 0 64px;
    }

    .contact-card {
        padding: 28px 20px;

        border-radius: 14px;
    }

    h2 {
        font-size: 2rem;
    }

    .primary-action {
        width: 100%;
    }

    .social-links {
        gap: 14px 18px;
    }
}
</style>