---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<span class="tech-tag">
  {name}
</span>

<style>
  .tech-tag {
    display: inline-flex;
    align-items: center;

    padding: 5px 9px;

    border: 1px solid var(--border);
    border-radius: 6px;

    background: var(--surface);
    color: var(--text-secondary);

    font-size: 0.72rem;
    font-weight: 550;
  }
</style>