---
import type { Experience } from "../content/types";
import TechTag from "./TechTag.astro";

interface Props {
  experience: Experience;
}

const { experience } = Astro.props;
---

<article class="experience-item">

  <header class="experience-header">

    <div class="company-info">

      <h3>
        {experience.company}
      </h3>

      <span class="role">
        {experience.role}
      </span>

    </div>

    <span class="period">
      {experience.period}
    </span>

  </header>


  <ul class="highlights">

    {
      experience.highlights.map((highlight) => (
        <li>
          {highlight}
        </li>
      ))
    }

  </ul>


  <div class="technologies">

    {
      experience.technologies.map((technology) => (
        <TechTag name={technology} />
      ))
    }

  </div>

</article>


<style>
  .experience-item {
    width: 100%;

    padding-bottom: 30px;
  }


  /* =========================
     HEADER
  ========================= */

  .experience-header {
    display: flex;

    align-items: flex-start;
    justify-content: space-between;

    gap: 32px;

    margin-bottom: 24px;
  }

  .company-info {
    min-width: 0;
  }

  h3 {
    margin: 0;

    color: var(--text-primary);

    font-size: 1.4rem;
    font-weight: 700;

    line-height: 1.25;

    letter-spacing: -0.035em;
  }

  .role {
    display: block;

    margin-top: 5px;

    color: var(--accent);

    font-size: 0.88rem;
    font-weight: 600;

    line-height: 1.5;
  }

  .period {
    padding-top: 5px;

    color: var(--text-secondary);

    font-size: 0.76rem;
    font-weight: 500;

    line-height: 1.5;

    white-space: nowrap;
  }


  /* =========================
     HIGHLIGHTS
  ========================= */

  .highlights {
    display: flex;
    flex-direction: column;

    gap: 14px;

    max-width: 880px;

    margin: 0;
    padding: 0;

    list-style: none;
  }

  .highlights li {
    position: relative;

    padding-left: 18px;

    color: var(--text-secondary);

    font-size: 0.86rem;
    font-weight: 400;

    line-height: 1.7;

    letter-spacing: -0.005em;

    overflow-wrap: break-word;
  }

  .highlights li::before {
    content: "";

    position: absolute;

    left: 0;
    top: 0.72em;

    width: 4px;
    height: 4px;

    border-radius: 50%;

    background: var(--accent);
  }


  /* =========================
     TECHNOLOGIES
  ========================= */

  .technologies {
    display: flex;
    flex-wrap: wrap;

    gap: 7px;

    margin-top: 22px;
  }


  /* =========================
     TABLET
  ========================= */

  @media (max-width: 760px) {

    .experience-item {
      padding-bottom: 52px;
    }

    .experience-header {
      flex-direction: column;

      gap: 6px;

      margin-bottom: 20px;
    }

    .period {
      order: -1;

      padding-top: 0;

      font-size: 0.72rem;
    }

    h3 {
      font-size: 1.25rem;
    }

    .role {
      font-size: 0.85rem;
    }

    .highlights {
      gap: 13px;
    }

    .highlights li {
      font-size: 0.85rem;
      line-height: 1.65;
    }
  }


  /* =========================
     MOBILE
  ========================= */

  @media (max-width: 520px) {

    .experience-item {
      padding-bottom: 44px;
    }

    .experience-header {
      margin-bottom: 18px;
    }

    h3 {
      font-size: 1.18rem;
    }

    .role {
      margin-top: 3px;

      font-size: 0.82rem;
    }

    .highlights {
      gap: 12px;
    }

    .highlights li {
      padding-left: 15px;

      font-size: 0.82rem;
      line-height: 1.65;
    }

    .technologies {
      gap: 6px;

      margin-top: 18px;
    }
  }
</style>